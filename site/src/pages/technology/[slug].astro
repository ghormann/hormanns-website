---
import { getCollection, render } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import YouTubeGrid from '../../components/YouTubeGrid.astro';
import PhotoGallery from '../../components/PhotoGallery.astro';
import FavDisplays from '../../components/FavDisplays.astro';

export async function getStaticPaths() {
  const entries = await getCollection('technology', ({ data }) => !data.draft);
  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, heroImage, heroImageAlt, videos, photos, sectionSidebars, showFavDisplays } = entry.data;
const ogImage = heroImage ?? undefined;
const abs = (p: string) => (p.startsWith('/') || p.startsWith('http') ? p : `/${p}`);
const heroSrc = heroImage ?? (photos?.[0]?.src ? abs(photos[0].src) : null);
const heroAlt = heroImageAlt ?? photos?.[0]?.caption ?? title;

// Build sidebar data for client script: resolve photo indices to actual photo objects
const clientPhotos = photos.map(p => ({
  src: abs(p.src),
  caption: p.caption,
  thumb: p.thumb ? abs(p.thumb) : undefined,
}));
const clientSidebars = sectionSidebars.map(s => ({
  heading: s.heading,
  maxPhotos: s.maxPhotos,
  photos: s.photoIndices.slice(0, s.maxPhotos).map(i => ({
    index: i,
    ...clientPhotos[i],
  })),
}));
---

<PageLayout title={`${title} — The Hormanns`} description={description} ogImage={ogImage}>
  <div class="rounded-lg px-6 py-4 mb-6 -mx-2" style="background-color: var(--color-accent);">
    <h1 class="text-3xl font-bold m-0" style="color: var(--color-heading);">{title}</h1>
  </div>

  {heroSrc && (
    <img
      src={heroSrc}
      alt={heroAlt}
      class="w-full rounded-lg shadow mb-6"
    />
  )}

  <div class="prose max-w-none mb-6 leading-relaxed">
    <Content />
  </div>

  {videos.length > 0 && (
    <>
      <h2 class="text-xl font-semibold mt-8 mb-2" style="color: var(--color-heading);">Videos</h2>
      <YouTubeGrid videos={videos} />
    </>
  )}

  {photos.length > 0 && (
    <>
      <h2 class="text-xl font-semibold mt-8 mb-2" style="color: var(--color-heading);">Photos</h2>
      <PhotoGallery photos={photos} />
    </>
  )}

  {showFavDisplays && <FavDisplays />}

  <div class="mt-8 pt-4 border-t" style="border-color: var(--color-accent);">
    <a href="/technology/" class="text-sm hover:underline" style="font-family: var(--font-sans); color: var(--color-link);">
      ← Back to Technology
    </a>
  </div>

  {clientSidebars.length > 0 && (
    <script define:vars={{ clientSidebars, allPhotos: clientPhotos }}>
      function buildSidebar(sidebarDef) {
        const col = document.createElement('div');
        col.className = 'section-sidebar';
        sidebarDef.photos.forEach(photo => {
          const thumb = photo.thumb ?? photo.src;
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'sidebar-thumb';
          btn.setAttribute('aria-label', photo.caption ?? 'View photo');
          btn.dataset.index = String(photo.index);
          const img = document.createElement('img');
          img.src = thumb;
          img.alt = photo.caption ?? '';
          img.loading = 'lazy';
          btn.appendChild(img);
          btn.addEventListener('click', () => {
            window.dispatchEvent(new CustomEvent('openLightbox', {
              detail: { photos: allPhotos, index: photo.index, opener: btn }
            }));
          });
          col.appendChild(btn);
        });
        return col;
      }

      function removeSidebars() {
        const prose = document.querySelector('.prose');
        if (!prose) return;
        prose.querySelectorAll('.section-with-sidebar').forEach(wrapper => {
          const textCol = wrapper.querySelector('.section-text');
          if (textCol) {
            while (textCol.firstChild) {
              prose.insertBefore(textCol.firstChild, wrapper);
            }
          }
          wrapper.remove();
        });
      }

      function injectSidebars() {
        const prose = document.querySelector('.prose');
        if (!prose) return;
        if (prose.querySelector('.section-with-sidebar')) return; // already injected

        const h2s = prose.querySelectorAll('h2');
        h2s.forEach(h2 => {
          const headingText = h2.textContent?.trim() ?? '';
          const def = clientSidebars.find(s => headingText.startsWith(s.heading.split('(')[0].trim()));
          if (!def || def.photos.length === 0) return;

          const sectionNodes = [h2];
          let node = h2.nextSibling;
          while (node && !(node.nodeType === 1 && node.tagName === 'H2')) {
            sectionNodes.push(node);
            node = node.nextSibling;
          }

          const wrapper = document.createElement('div');
          wrapper.className = 'section-with-sidebar';
          const textCol = document.createElement('div');
          textCol.className = 'section-text';
          sectionNodes.forEach(n => textCol.appendChild(n));
          const sidebar = buildSidebar(def);
          wrapper.appendChild(textCol);
          wrapper.appendChild(sidebar);

          if (node) {
            prose.insertBefore(wrapper, node);
          } else {
            prose.appendChild(wrapper);
          }
        });
      }

      function updateSidebars() {
        if (window.innerWidth >= 900) {
          injectSidebars();
        } else {
          removeSidebars();
        }
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', updateSidebars);
      } else {
        updateSidebars();
      }

      let resizeTimer;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(updateSidebars, 100);
      });
    </script>
  )}
</PageLayout>

<style>
  .prose p { margin-bottom: 1em; }
  :global(.prose p) { margin-bottom: 12px; }
  :global(.prose ul) { list-style-type: disc; padding-left: 1.5em; margin-bottom: 1em; }
  :global(.prose ol) { list-style-type: decimal; padding-left: 1.5em; margin-bottom: 1em; }
  :global(.prose li) { margin-bottom: 0.25em; }
  :global(.prose h2) { color: var(--color-heading); margin-top: 1.5em; margin-bottom: 0.5em; font-size: 1.25rem; font-weight: 600; }
  :global(.prose h3) { color: var(--color-heading); margin-top: 1.5em; margin-bottom: 0.5em; }
  .prose img { max-width: 100%; border-radius: 0.5rem; }
  :global(.prose table) { border-collapse: collapse; width: 100%; margin-bottom: 1em; font-size: 0.9em; }
  :global(.prose th), :global(.prose td) { border: 1px solid var(--color-accent); padding: 0.4em 0.75em; text-align: left; }
  :global(.prose th) { background-color: var(--color-accent); font-weight: 600; color: var(--color-heading); }
  :global(.prose tr:nth-child(even) td) { background-color: color-mix(in srgb, var(--color-accent) 40%, transparent); }

  :global(.section-with-sidebar) {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }
  :global(.section-text) {
    flex: 1 1 0;
    min-width: 0;
  }
  :global(.section-sidebar) {
    flex: 0 0 240px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-top: 0.25rem;
  }
  :global(.sidebar-thumb) {
    display: block;
    width: 100%;
    border: none;
    padding: 0;
    background: none;
    cursor: pointer;
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 1px 4px rgba(0,0,0,0.25);
    transition: transform 0.15s, box-shadow 0.15s;
  }
  :global(.sidebar-thumb:hover) {
    transform: scale(1.04);
    box-shadow: 0 3px 8px rgba(0,0,0,0.35);
  }
  :global(.sidebar-thumb img) {
    display: block;
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
  }
</style>
