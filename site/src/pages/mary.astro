---
import PageLayout from '../layouts/PageLayout.astro';
import FavDisplays from '../components/FavDisplays.astro';
---

<PageLayout title="Meet Mary Hormann" description="Mary Hormann — Greg's wife and partner in all things Christmas.">

  <div class="rounded-lg px-6 py-4 mb-8 -mx-2" style="background-color: var(--color-accent);">
    <h1 class="text-3xl font-bold m-0" style="color: var(--color-heading);">Meet Mary Hormann</h1>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
    <div class="sm:col-span-2 leading-relaxed brown-links">
      <p class="mb-4">
        One of these days I'll add something, but for now check out my favorite displays at
        <a href="http://cooldisplays.net">CoolDisplays.net</a>.
      </p>
      <p class="mb-4">
        Mary graduated from <a href="http://www.iub.edu">Indiana University</a>
        and met <a href="/greg/">Greg</a> there.
        They moved to Cincinnati, OH after college and were married on November 4, 2000.
      </p>
    </div>
    <div class="flex justify-center items-start">
      <a href="/wedding/Honeymoon/mary_hair.jpg">
        <img
          src="/wedding/Honeymoon/_mary_hair.jpg"
          alt="Mary Hormann"
          class="rounded-lg shadow"
          width="135"
        />
      </a>
    </div>
  </div>

  <FavDisplays wide token="2d1093076abd3bd9d58dd9a3ee698b5ci3idb88fe3e8035e3ed6da0ccd6dbb238cb44f35565" />

</PageLayout>
