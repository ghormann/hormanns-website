---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';

const christmasYears = (await getCollection('christmas', ({ data }) => !data.draft))
  .sort((a, b) => b.data.year - a.data.year);

const technologyPages = (await getCollection('technology', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
---

<PageLayout title="Site Map" description="Complete map of all pages on TheHormanns.net.">

  <div class="rounded-lg px-6 py-4 mb-8 -mx-2" style="background-color: var(--color-amber);">
    <h1 class="text-3xl font-bold m-0" style="color: var(--color-brown);">Site Map</h1>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-sm" style="font-family: var(--font-sans);">

    <div>
      <h2 class="font-semibold text-base mb-3" style="color: var(--color-brown);">Main Pages</h2>
      <ul class="space-y-1">
        <li><a href="/" class="underline" style="color: var(--color-brown-light);">Home Page</a></li>
        <li><a href="/greg/" class="underline" style="color: var(--color-brown-light);">Greg's Page</a></li>
        <li><a href="/mary/" class="underline" style="color: var(--color-brown-light);">Mary's Page</a></li>
        <li><a href="/pictures/" class="underline" style="color: var(--color-brown-light);">Pictures</a></li>
        <li><a href="/sitemap/" class="underline" style="color: var(--color-brown-light);">Site Map</a></li>
      </ul>

      <h2 class="font-semibold text-base mt-6 mb-3" style="color: var(--color-brown);">Technology</h2>
      <ul class="space-y-1">
        <li><a href="/technology/" class="underline" style="color: var(--color-brown-light);">Technology Overview</a></li>
        {technologyPages.map(page => (
          <li>
            <a href={`/technology/${page.id}/`} class="underline" style="color: var(--color-brown-light);">
              {page.data.title}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="sm:col-span-2">
      <h2 class="font-semibold text-base mb-3" style="color: var(--color-brown);">Christmas Display — By Year</h2>
      <ul class="grid grid-cols-2 gap-x-4 gap-y-1">
        <li><a href="/christmas/" class="underline" style="color: var(--color-brown-light);">Christmas Overview</a></li>
        {christmasYears.map(year => (
          <li>
            <a href={`/christmas/${year.data.year}/`} class="underline" style="color: var(--color-brown-light);">
              {year.data.title}
            </a>
          </li>
        ))}
      </ul>
    </div>

  </div>

</PageLayout>
