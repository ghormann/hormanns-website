---
import { getCollection } from "astro:content";
import PageLayout from "../layouts/PageLayout.astro";
import PhotoGallery from "../components/PhotoGallery.astro";

const christmasYears = (
  await getCollection("christmas", ({ data }) => !data.draft)
)
  .sort((a, b) => b.data.year - a.data.year)
  .filter((y) => y.data.photos && y.data.photos.length > 0);

const technologyPages = (
  await getCollection("technology", ({ data }) => !data.draft)
)
  .sort((a, b) => a.data.order - b.data.order)
  .filter((t) => t.data.photos && t.data.photos.length > 0);
---

<PageLayout
  title="Our Pictures"
  description="Christmas display photos and family pictures from the Hormanns."
>
  <div
    class="rounded-lg px-6 py-4 mb-8 -mx-2"
    style="background-color: var(--color-accent);"
  >
    <h1 class="text-3xl font-bold m-0" style="color: var(--color-heading);">
      Pictures
    </h1>
  </div>

  <section class="mt-8">
    <h2 class="text-xl font-semibold mb-4" style="color: var(--color-heading);">
      Family Pictures
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-[1fr_auto] gap-8 leading-relaxed brown-links">
      <p>
        We have a few pictures available publicly on this page, but if you have
        some you would like to contribute, please
        <a href="mailto:ghormann@gmail.com">let us know</a>. Our family pictures
        are password protected. Need a password? Then
        <a href="mailto:ghormann@gmail.com">email us</a>.
      </p>
      <div>
        <a href="/wedding/reception/cake3.jpg">
          <img
            src="/wedding/reception/_cake3.jpg"
            alt="Wedding Cake"
            width="174"
            class="rounded shadow"
          />
        </a>
      </div>
    </div>
    <br />
  </section>

  <section class="mb-10">
    <h2 class="text-xl font-semibold mb-2" style="color: var(--color-heading);">
      Technology
    </h2>
    {
      technologyPages.map((page) => (
        <div class="mb-6">
          <h3 class="text-base font-semibold mb-1" style="color: var(--color-heading);">
            <a href={`/technology/${page.id}/`} class="brown-links">{page.data.title}</a>
          </h3>
          <PhotoGallery photos={page.data.photos} id={`gallery-tech-${page.id}`} />
        </div>
      ))
    }
  </section>

  {
    christmasYears.map((year) => (
      <section class="mb-10">
        <h2
          class="text-xl font-semibold mb-2"
          style="color: var(--color-heading);"
        >
          <a href={`/christmas/${year.data.year}/`} class="brown-links">
            {year.data.title}
          </a>
        </h2>
        <PhotoGallery
          photos={year.data.photos}
          id={`gallery-${year.data.year}`}
        />
      </section>
    ))
  }
</PageLayout>
