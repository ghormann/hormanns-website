---
import PageLayout from '../layouts/PageLayout.astro';
import RecentDisplays from '../components/RecentDisplays.astro';
import YouTubeGrid from '../components/YouTubeGrid.astro';
import FavDisplays from '../components/FavDisplays.astro';

const historyVideo = [{ id: 'Nd7ADGezo3s', title: 'Video History of our Display' }];

const websiteJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      name: 'The Hormanns',
      url: 'https://www.thehormanns.net',
    },
    {
      '@type': 'Person',
      name: 'Greg Hormann',
      url: 'https://www.thehormanns.net/greg/',
    },
    {
      '@type': 'Person',
      name: 'Mary Hormann',
      url: 'https://www.thehormanns.net/mary/',
    },
  ],
});
---

<PageLayout
  title="Greg and Mary Hormann — Liberty Township, Ohio"
  description="The personal website of Greg and Mary Hormann — family, Christmas lights, and technology in Liberty Township, Ohio (Cincinnati area)."
  ogImage="/christmas/2025/the_hormanns_2025.jpg"
  jsonLd={websiteJsonLd}
>

  <!-- Hero heading -->
  <div class="rounded-lg px-6 py-4 mb-8 -mx-2" style="background-color: var(--color-accent);">
    <h1 class="text-3xl font-bold m-0" style="color: var(--color-heading);">Meet Greg and Mary Hormann</h1>
  </div>

  <!-- About section -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-10">
    <div class="sm:col-span-2 brown-links">
      <p class="leading-relaxed mb-4">
        <a href="/greg/">Greg</a> and
        <a href="/mary/">Mary</a> became
        friends in high school at
        <a href="http://www.wawasee.k12.in.us/">Wawasee High School</a>
        in Syracuse, IN. Both separately decided to attend
        <a href="http://www.iub.edu">Indiana University</a>
        in Bloomington, Indiana. Greg and Mary began dating during their freshman year, and both
        ended up moving to Cincinnati after college. On November 4, 2000 — exactly 6 years from
        their first date — the couple were wed at All Saints Catholic Church in Cincinnati, Ohio.
      </p>
    </div>
    <div class="flex justify-center items-start">
      <img
        src="/wedding/reception/_greg_mary_dancing.jpg"
        alt="Greg & Mary Dancing"
        class="rounded-lg shadow max-h-48 object-cover"
      />
    </div>
  </div>

  <!-- Christmas display section -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-10">
    <div class="sm:col-span-2 brown-links">
      <h2 class="text-xl font-semibold mb-3" style="color: var(--color-heading);">Christmas Display</h2>
      <p class="leading-relaxed mb-3">
        Both of us are big on <a href="/christmas/">Christmas</a>.
        Mary likes the shopping and interior decorating, and Greg is big on outside Christmas displays.
        In <a href="/christmas/2001/">2001</a>, Greg
        started experimenting with animated displays controlled by a computer. Twenty-five years later, we have over 75,000 lights synchronized to 73 minutes of music leveraging
        <a href="https://xlights.org" target="_blank" rel="noopener noreferrer">xLights</a>,
        <a href="https://github.com/FalconChristmas/fpp" target="_blank" rel="noopener noreferrer">FPP</a>,
        and <a href="/technology/dmx/">pixels controlled by E1.31</a>.
        If you are curious about the history of our display, we've captured <a href="/christmas/our-story/">our story</a>
        which is also summarized in a <a href="https://www.youtube.com/watch?v=Nd7ADGezo3s">2021 on stage presentation</a>.
      </p>
      <RecentDisplays />
    </div>
    <div>
      <a href="/christmas/">
        <img
          class="rounded-lg shadow w-full mb-4"
          src="https://cooldisplays.net/picture.php?v=1764536045&pictid=278&width=400"
          alt="Hormann Christmas Display"
        />
      </a>
      <YouTubeGrid videos={historyVideo} cols={1} />
    </div>
  </div>

  <!-- More section -->
  <h2 class="text-lg font-semibold mt-10 mb-2" style="color: var(--color-heading);">Looking for more?</h2>
  <p class="text-sm brown-links" style="font-family: var(--font-sans);">
    Check out the <a href="/sitemap/">site map</a>
    to learn about everything this site has to offer.
  </p>

  <FavDisplays wide />

</PageLayout>
