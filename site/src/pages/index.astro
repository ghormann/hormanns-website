---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import YearCard from '../components/YearCard.astro';
import YouTubeGrid from '../components/YouTubeGrid.astro';
import FavDisplays from '../components/FavDisplays.astro';

const recentYears = (await getCollection('christmas', ({ data }) => !data.draft))
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 6);

const historyVideo = [{ id: 'Nd7ADGezo3s', title: 'Video History of our Display' }];
---

<PageLayout title="Greg and Mary Hormann" description="The personal website of Greg and Mary Hormann — family, Christmas lights, and technology.">

  <!-- Hero heading -->
  <div class="rounded-lg px-6 py-4 mb-8 -mx-2" style="background-color: var(--color-amber);">
    <h1 class="text-3xl font-bold m-0" style="color: var(--color-brown);">Meet Greg and Mary Hormann</h1>
  </div>

  <!-- About section -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-10">
    <div class="sm:col-span-2">
      <p class="leading-relaxed mb-4">
        <a href="/greg/" class="underline" style="color: var(--color-brown-light);">Greg</a> and
        <a href="/mary/" class="underline" style="color: var(--color-brown-light);">Mary</a> became
        friends in high school at
        <a href="http://www.wawasee.k12.in.us/" class="underline" style="color: var(--color-brown-light);">Wawasee High School</a>
        in Syracuse, IN. Both separately decided to attend
        <a href="http://www.iub.edu" class="underline" style="color: var(--color-brown-light);">Indiana University</a>
        in Bloomington, Indiana. Greg and Mary began dating during their freshman year, and both
        ended up moving to Cincinnati after college. On November 4, 2000 — exactly 6 years from
        their first date — the couple were wed at All Saints Catholic Church in Cincinnati, Ohio.
      </p>
    </div>
    <div class="flex justify-center items-start">
      <a href="/wedding/reception/greg_mary_dancing.jpg">
        <img
          src="/wedding/reception/_greg_mary_dancing.jpg"
          alt="Greg & Mary Dancing"
          class="rounded-lg shadow max-h-48 object-cover"
        />
      </a>
    </div>
  </div>

  <!-- Christmas display section -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-10">
    <div class="sm:col-span-2">
      <h2 class="text-xl font-semibold mb-3" style="color: var(--color-brown);">Christmas Display</h2>
      <p class="leading-relaxed mb-3">
        Both of us are big on <a href="/christmas/" class="underline" style="color: var(--color-brown-light);">Christmas</a>.
        Mary likes the shopping and interior decorating, and Greg is big on outside Christmas displays.
        In <a href="/christmas/2001/" class="underline" style="color: var(--color-brown-light);">2001</a>, Greg
        started experimenting with animated displays controlled by a computer. These days, we leverage
        <a href="https://xlights.org" class="underline" style="color: var(--color-brown-light);" target="_blank" rel="noopener noreferrer">xLights</a>,
        <a href="https://github.com/FalconChristmas/fpp" class="underline" style="color: var(--color-brown-light);" target="_blank" rel="noopener noreferrer">FPP</a>,
        and <a href="/technology/dmx/" class="underline" style="color: var(--color-brown-light);">pixels controlled by E1.31</a>.
      </p>
      <h2 class="text-lg font-semibold mb-3" style="color: var(--color-brown);">Recent Displays</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-2">
        {recentYears.map(y => (
          <YearCard
            year={y.data.year}
            heroImage={y.data.heroImage}
          />
        ))}
      </div>
      <p class="text-sm" style="font-family: var(--font-sans);">
        <a href="/christmas/" class="underline" style="color: var(--color-brown-light);">See all years →</a>
      </p>
    </div>
    <div>
      <a href="/christmas/">
        <img
          class="rounded-lg shadow w-full mb-4"
          src="https://cooldisplays.net/picture.php?v=1764536045&pictid=278&width=400"
          alt="Hormann Christmas Display"
        />
      </a>
      <YouTubeGrid videos={historyVideo} cols={1} />
    </div>
  </div>

  <!-- More section -->
  <h2 class="text-lg font-semibold mt-10 mb-2" style="color: var(--color-brown);">Looking for more?</h2>
  <p class="text-sm" style="font-family: var(--font-sans);">
    Check out the <a href="/sitemap/" class="underline" style="color: var(--color-brown-light);">site map</a>
    to learn about everything this site has to offer.
  </p>

  <FavDisplays wide />

</PageLayout>
