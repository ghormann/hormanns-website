---
import { getCollection } from 'astro:content';
import YearCard from './YearCard.astro';

const recentYears = (await getCollection('christmas', ({ data }) => !data.draft))
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 6);
---

<h2 class="text-lg font-semibold mb-3" style="color: var(--color-heading);">Recent Displays</h2>
<div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-2">
  {recentYears.map(y => (
    <YearCard year={y.data.year} heroImage={y.data.heroImage} />
  ))}
</div>
<p class="text-sm brown-links" style="font-family: var(--font-sans);">
  <a href="/christmas/">See all years →</a>
</p>
