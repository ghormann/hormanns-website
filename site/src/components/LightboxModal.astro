---
---

<dialog id="lightbox" aria-label="Photo lightbox">

  <!-- Prev / Next — fixed to viewport edges, vertically centered -->
  <button id="lightbox-prev" aria-label="Previous photo" class="lb-nav lb-nav-prev">‹</button>
  <button id="lightbox-next" aria-label="Next photo"     class="lb-nav lb-nav-next">›</button>

  <!-- Close — fixed top-right -->
  <button id="lightbox-close" aria-label="Close" class="lb-close">✕</button>

  <!-- Image with caption overlay -->
  <div id="lightbox-inner" style="position:relative;display:inline-block;line-height:0;">
    <img
      id="lightbox-img"
      src=""
      alt=""
      style="max-width: min(88vw, 1200px); max-height: 88vh; object-fit: contain; border-radius: 0.375rem; display: block;"
    />
    <!-- Caption gradient overlay (screen readers announced on change) -->
    <div id="lightbox-caption-area" aria-live="polite" class="lb-caption-area">
      <p id="lightbox-caption" class="lb-caption-text"></p>
    </div>
  </div>

</dialog>

<style>
  /* Nav arrows — absolute within the full-viewport dialog */
  .lb-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(0, 0, 0, 0.50);
    border: none;
    cursor: pointer;
    color: #fff;
    font-size: 2rem;
    line-height: 1;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.15s;
    z-index: 10;
  }
  .lb-nav:hover { background: rgba(0, 0, 0, 0.75); }
  .lb-nav-prev { left: 1rem; }
  .lb-nav-next { right: 1rem; }

  /* Close — top-right corner */
  .lb-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: rgba(0, 0, 0, 0.50);
    border: none;
    cursor: pointer;
    color: #fff;
    font-size: 1rem;
    line-height: 1;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.15s;
    z-index: 10;
  }
  .lb-close:hover { background: rgba(0, 0, 0, 0.75); }

  /* Caption gradient overlaid on image bottom */
  .lb-caption-area {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.65));
    border-radius: 0 0 0.375rem 0.375rem;
    padding: 2rem 1rem 0.75rem;
    text-align: center;
  }
  .lb-caption-text {
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    margin: 0;
  }
</style>

<script>
  const dialog   = document.getElementById('lightbox') as HTMLDialogElement;
  const inner    = document.getElementById('lightbox-inner') as HTMLDivElement;
  const imgEl    = document.getElementById('lightbox-img') as HTMLImageElement;
  const captArea = document.getElementById('lightbox-caption-area') as HTMLDivElement;
  const caption  = document.getElementById('lightbox-caption') as HTMLParagraphElement;
  const prevBtn  = document.getElementById('lightbox-prev') as HTMLButtonElement;
  const nextBtn  = document.getElementById('lightbox-next') as HTMLButtonElement;
  const closeBtn = document.getElementById('lightbox-close') as HTMLButtonElement;

  interface Photo { src: string; caption?: string; thumb?: string; }

  let photos: Photo[] = [];
  let currentIndex = 0;
  let opener: HTMLElement | null = null;

  function updateSlide() {
    const photo = photos[currentIndex];
    const total = photos.length;
    imgEl.src = photo.src;
    imgEl.alt = photo.caption ?? `Photo ${currentIndex + 1} of ${total}`;
    if (total === 1) {
      prevBtn.hidden = true;
      nextBtn.hidden = true;
      caption.textContent = photo.caption ?? '';
    } else {
      prevBtn.hidden = false;
      nextBtn.hidden = false;
      const counter = `${currentIndex + 1} / ${total}`;
      caption.textContent = photo.caption ? `${photo.caption} — ${counter}` : counter;
    }
    captArea.style.display = caption.textContent ? '' : 'none';
  }

  function doClose() {
    if (dialog.classList.contains('closing')) return;
    dialog.classList.add('closing');
    dialog.addEventListener('transitionend', () => {
      dialog.classList.remove('closing');
      dialog.close();
      opener?.focus();
    }, { once: true });
  }

  // Open: triggered by PhotoGallery
  window.addEventListener('openLightbox', (e: Event) => {
    const { photos: p, index, opener: op } = (e as CustomEvent).detail as {
      photos: Photo[];
      index: number;
      opener: HTMLElement;
    };
    photos = p;
    currentIndex = index;
    opener = op ?? null;
    updateSlide();
    dialog.showModal();
  });

  // Close button
  closeBtn.addEventListener('click', doClose);

  // Backdrop click: fires on dialog itself (inner wrapper stops propagation)
  dialog.addEventListener('click', (e) => {
    if (e.target === dialog) doClose();
  });

  // Inner wrapper: stop clicks from bubbling to dialog (prevents accidental close)
  inner.addEventListener('click', (e) => e.stopPropagation());

  // Esc key: intercept native cancel to apply fade-out first
  dialog.addEventListener('cancel', (e) => {
    e.preventDefault();
    doClose();
  });

  // Navigation buttons
  prevBtn.addEventListener('click', () => {
    currentIndex = (currentIndex - 1 + photos.length) % photos.length;
    updateSlide();
  });
  nextBtn.addEventListener('click', () => {
    currentIndex = (currentIndex + 1) % photos.length;
    updateSlide();
  });

  // Keyboard navigation (only when dialog is open)
  dialog.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft')  { currentIndex = (currentIndex - 1 + photos.length) % photos.length; updateSlide(); }
    if (e.key === 'ArrowRight') { currentIndex = (currentIndex + 1) % photos.length; updateSlide(); }
  });
</script>
