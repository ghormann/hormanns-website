---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'The Hormann Family Website' } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="author" content="Greg Hormann" />
  <meta name="keywords" content="Greg, Mary, Hormann, Christmas" />
  <meta name="description" content={description} />
  <meta name="google-site-verification" content="Wm_ACFhrB0gCaV1A9Xq2b1gBr6e4S7F04bavC20BcKY" />
  <title>{title}</title>

  <!-- Google Fonts: Lora (serif body) + Inter (sans UI) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Lora:ital,wght@0,400;0,600;1,400&display=swap"
    rel="stylesheet"
  />

  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=UA-16040992-1"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'UA-16040992-1');
  </script>
</head>
<body>
  <slot />
</body>
</html>
