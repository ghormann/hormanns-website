function Christmas_submenu() {
   $years = Christmas_details();
 
   $last_group = "blank";

   foreach ($years as $y) {
      $label = $y[0];
      $url = $y[1];
      $group = $y[2];

      if ($last_group != $group) {
         if ($last_group != "blank") {
            echo("</ul></li>");
         }
         echo("  <li class=\"dropdown-item dropdown-submenu\">");
         echo("       <a href=\"#\" data-toggle=\"dropdown\" class=\"dropdown-toggle\">$group</a>");
         echo("       <ul class=\"dropdown-menu\">");
         $last_group = $group;
      } /* End group change */
     
     echo("       <li class=\"dropdown-item\"><a href = \"$url\">$label</a></li>");
   }
  
 
    echo("</ul></li>"); /* CLose final submenu */
}


function Christmas_simple($preFix = "", $suffix="", $htmlClass="", $reverse=False) {
        $years = Christmas_details();
        if ($reverse) {
            $years = array_reverse($years);
        }


        foreach ($years as $y) {
           $label = $y[0];
           $url = $y[1];
	   echo " $preFix <a $htmlClass href = \"$url\">$label</a> $suffix";
        }

}

Function Christmas_years() {
	Christmas_simple();
