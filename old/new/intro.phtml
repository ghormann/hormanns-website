function labledPicture($myclass, $pics, $text, $thumb)
{
   if ($thumb === ''){
      $thumb = $pics;
   }
   echo("<figure class=\"$myclass\">\n");
   echo("\t<a href=\"$pics\">\n");
   echo("\t\t<img src=\"$thumb\">\n");
   echo("\t<figcaption>$text</figcaption></a>\n");
   echo("</figure>\n");
}

function youtubeVideo($movies, $imgClass="youtubeVideo") {
   foreach ($movies as $movData)
      {
         $mov = $movData[0];
         $label = $movData[1];
         $thumb = "https://img.youtube.com/vi/$mov/maxresdefault.jpg";
         if (count($movData) > 2) 
         {
            $thumb = $movData[2];
         }
         echo("<figure class=\"$imgClass\" >");
         echo("<a href=\"https://www.youtube.com/watch?v=$mov\">");
         echo("<img src=\"$thumb\" >");
         echo("<figcaption>$label</figcaption>");
         echo("</a>");
         echo("</figure>");
      }
}

